import java.util.Random;
import java.util.Arrays;

public class ArregloOrdenamiento {

    private int[] datos;

    // Constructor 1
    public ArregloOrdenamiento(int cantidad) {
        datos = new int[cantidad];
    }

    // Constructor 2
    public ArregloOrdenamiento(int[] datos) {
        this.datos = datos;
    }

    // Burbuja
    public void burbuja(int[] datos) {
        for (int pasada = 1; pasada < datos.length; pasada++) {
            for (int i = 0; i < datos.length - 1; i++) {
                if (datos[i] > datos[i + 1]) {
                    int temp = datos[i];
                    datos[i] = datos[i + 1];
                    datos[i + 1] = temp;
                }
            }
        }
    }

    // Selección
    public void orden(int[] datos) {
        int n = datos.length;

        for (int i = 0; i < n - 1; i++) {
            int indiceMinimo = i;

            for (int j = i + 1; j < n; j++) {
                if (datos[j] < datos[indiceMinimo]) {
                    indiceMinimo = j;
                }
            }

            int temp = datos[indiceMinimo];
            datos[indiceMinimo] = datos[i];
            datos[i] = temp;
        }
    }

    // Llenar aleatorio
    public void llenarAleatorio(int limite) {
        Random aleatorio = new Random();

        for (int i = 0; i < datos.length; i++) {
            datos[i] = aleatorio.nextInt(limite);
        }
    }

    // toString
    @Override
    public String toString() {
        return Arrays.toString(datos);
    }

  
    public static void main(String[] args) {
        ArregloOrdenamiento arr = new ArregloOrdenamiento(10);

        arr.llenarAleatorio(100);
        System.out.println("Arreglo original:");
        System.out.println(arr);

        arr.burbuja(arr.datos);
        System.out.println("Ordenado con burbuja:");
        System.out.println(arr);

        // Volver a llenar
        arr.llenarAleatorio(100);
        System.out.println("Nuevo arreglo:");
        System.out.println(arr);

        arr.orden(arr.datos);
        System.out.println("Ordenado con selección:");
        System.out.println(arr);
    }
}
